# Apps Script endpoint for the Google Sheet Bridge.
# Leave empty to use manual endpoint entry in the /os/bridge UI.
# Do not commit private endpoint values. Use .env.local instead.
VITE_APPS_SCRIPT_KARUN_ENDPOINT=

# Optional Finnhub API key for manual delayed market refresh.
# Leave empty for fallback mode. Use .env.local. Do not commit real keys.
VITE_FINNHUB_API_KEY=

# Firebase portfolio production persistence.
# Leave blank to use local/mock portfolio storage in development.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
